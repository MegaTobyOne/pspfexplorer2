{
  "name": "pspf-explorer-2-0",
  "version": "2.0.0-alpha.1",
  "description": "Offline-first compliance management for the Australian Government Protective Security Policy Framework (PSPF) 2025.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0"
  },
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:prod": "PSPF_BASE=/ playwright test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "perf:budget": "node scripts/perf-budget.mjs",
    "refresh:framework-data": "node scripts/refresh-framework-data.mjs",
    "sbom": "cyclonedx-npm --package-lock-only --output-file sbom.json --omit dev"
  },
  "dependencies": {
    "@lit/context": "1.1.6",
    "@preact/signals-core": "1.14.1",
    "cytoscape": "^3.33.3",
    "idb": "8.0.3",
    "lit": "3.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ]
}
